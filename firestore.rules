rules_version = '2';

// SpartansAttend Firestore security rules.
// Security model: the app's Firebase config is public (it ships in the app
// binary), so these rules are the real boundary. Default-deny; every collection
// the app uses is listed explicitly. Privilege fields (role, adminScopes,
// group*) can only be set by an admin (or in the Firebase console, which
// bypasses rules) — never by the account itself.
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ----
    function isSignedIn() { return request.auth != null; }
    function isSelf(uid) { return isSignedIn() && request.auth.uid == uid; }
    // The requesting user's own /users doc (used for role/scope checks). Only
    // call after isSignedIn() so it short-circuits when logged out.
    function reqUser() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isAdmin() { return isSignedIn() && reqUser().role == 'admin'; }
    function hasScope(s) { return isSignedIn() && (s in reqUser().get('adminScopes', [])); }
    // Designated parikshan scorers (a student can be a scorer) — they need to
    // read the roster and read/write the score collections.
    function isScorer() { return isSignedIn() && reqUser().get('isScorer', false) == true; }
    function changed(keys) { return request.resource.data.diff(resource.data).affectedKeys().hasAny(keys); }
    function onlyChanged(keys) { return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys); }

    // ---- Users ----
    match /users/{uid} {
      // Own doc always; admins, roster-scoped admins, and scorers read others.
      allow read: if isSelf(uid) || isAdmin() || isScorer() || hasScope('costume') || hasScope('donation');

      // Self-registration: a plain student only; cannot self-grant power.
      allow create: if isSelf(uid)
        && request.resource.data.role == 'student'
        && !request.resource.data.keys().hasAny(['adminScopes', 'group', 'groupRole', 'groupLead']);

      // Admin: anything. Self: profile fields only — never role/scope/group/email.
      // Costume admin: only the handout flags, on anyone's doc.
      allow update: if isAdmin()
        || (isSelf(uid) && !changed(['role', 'adminScopes', 'group', 'groupRole', 'groupLead', 'groupBaseName', 'email', 'tier', 'isScorer', 'isSuperAdmin']))
        || (hasScope('costume') && onlyChanged(['kurtaReceived', 'jacketReceived', 'costumeReceived']));

      allow delete: if isAdmin();
    }

    // ---- Sessions (admin-managed; everyone signed in reads to mark/see) ----
    match /sessions/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---- Attendance (own records + admin) ----
    match /attendance/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.studentId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // ---- Attendance correction requests (student creates own; admin reviews) ----
    match /attendanceCorrectionRequests/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ---- Parikshan scores (doc id = "<uid>_<season>"): own + admin read, admin write ----
    match /parikshanScores/{id} {
      allow read: if isAdmin() || isScorer() || (isSignedIn() && id.split('_')[0] == request.auth.uid);
      allow write: if isAdmin() || isScorer();
    }
    match /finalParikshanScores/{id} {
      allow read: if isAdmin() || isScorer() || (isSignedIn() && id.split('_')[0] == request.auth.uid);
      allow write: if isAdmin() || isScorer();
    }

    // ---- Events + RSVPs ----
    // ROLLOUT NOTE: read is intentionally open to any signed-in user for now,
    // because the CURRENTLY SHIPPED app lists events without a published filter.
    // Once the new build (whose student query filters where('published','==',
    // true)) is live and adopted, tighten read to the publish gate:
    //     allow read: if isAdmin() || resource.data.published == true;
    match /events/{eventId} {
      allow read: if isSignedIn();
      // Admins manage events. A signed-in student may bump ONLY goingCount, and
      // only by +1, when they RSVP "Going" — everything else is admin-only.
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (isSignedIn()
            && onlyChanged(['goingCount'])
            && request.resource.data.goingCount == resource.data.get('goingCount', 0) + 1);
      match /rsvps/{uid} {
        allow read: if isSignedIn();
        allow write: if isSelf(uid) || isAdmin();
      }
    }

    // ---- Season / config (everyone reads; admin writes) ----
    match /globalConfig/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---- Announcements (everyone reads; admin writes) ----
    match /notifications/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // No catch-all: anything not matched above is denied.
  }
}
